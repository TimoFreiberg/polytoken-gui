<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchDaemon template for the headless pantoken server.
  A system LaunchDaemon (not a per-user LaunchAgent) so it starts at boot
  with nobody logged in — the Mac Mini runs and reboots headlessly.
  It runs as the configured user via <UserName> so runtime keeps your perms/env.

  Do NOT install this file directly. A render step replaces @@@PLACEHOLDER@@@
  tokens with the absolute paths for this host, then a bootstrap script
  installs the rendered plist via sudo.

  Secrets are NOT here: run.sh sources them from ~/.local/state/pantoken/pantoken.env.
  See deploy/DEPLOY.md and deploy/bootstrap-headless.sh.

  Required placeholders:
    @@@USER@@@       — the runtime user (e.g. timo)
    @@@HOME@@@       — absolute home directory for that user
    @@@LIVE@@@       — ~/pantoken-live symlink target (absolute)
    @@@LOGDIR@@@     — absolute log directory
    @@@POLYTOKEN_BIN@@@ — absolute path to the polytoken daemon binary
    @@@XDG_CONFIG@@@ — absolute XDG_CONFIG_HOME path
    @@@XDG_DATA@@@   — absolute XDG_DATA_HOME path
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pantoken.server</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>@@@LIVE@@@/run.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>@@@LIVE@@@</string>

  <key>UserName</key>
  <string>@@@USER@@@</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>@@@HOME@@@</string>
    <key>PATH</key>
    <string>@@@HOME@@@/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>PANTOKEN_DATA_DIR</key>
    <string>@@@HOME@@@/.local/state/pantoken</string>
    <key>PANTOKEN_HOST</key>
    <string>127.0.0.1</string>
    <key>PANTOKEN_PORT</key>
    <string>8787</string>
    <key>PANTOKEN_POLYTOKEN_BIN</key>
    <string>@@@POLYTOKEN_BIN@@@</string>
    <key>XDG_CONFIG_HOME</key>
    <string>@@@XDG_CONFIG@@@</string>
    <key>XDG_DATA_HOME</key>
    <string>@@@XDG_DATA@@@</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>@@@LOGDIR@@@/pantoken.out.log</string>
  <key>StandardErrorPath</key>
  <string>@@@LOGDIR@@@/pantoken.err.log</string>
</dict>
</plist>
