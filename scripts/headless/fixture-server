#!/usr/bin/env python3
"""Deterministic fixture HTTP server for updater tests.

Serves:
  GET /health  -> {"ok":true} or {"ok":false} based on env
  GET /        -> HTML document with version identifier
  GET /ws      -> 101 Switching Protocols (stub WebSocket)

Controlled via environment:
  FIXTURE_PORT          - listen port (default: 0 = auto)
  FIXTURE_HEALTH_BODY   - response body for /health (default: {"ok":true})
  FIXTURE_HTML_VERSION  - version string embedded in HTML
  FIXTURE_FAIL_HEALTH   - if "1", /health returns {"ok":false}
  FIXTURE_RUN_DIR       - working directory (for data files)
  FIXTURE_BUILD_SHA     - build SHA embedded in HTML

Port is printed to stdout for the test harness to capture.
"""
import http.server
import json
import os
import socketserver
import sys

PORT = int(os.environ.get("FIXTURE_PORT", "0"))
HEALTH_BODY = os.environ.get("FIXTURE_HEALTH_BODY", '{"ok":true}')
HTML_VERSION = os.environ.get("FIXTURE_HTML_VERSION", "test-0.0.1")
FAIL_HEALTH = os.environ.get("FIXTURE_FAIL_HEALTH", "0") == "1"
RUN_DIR = os.environ.get("FIXTURE_RUN_DIR", "/tmp")
BUILD_SHA = os.environ.get("FIXTURE_BUILD_SHA", "abcdef1234567890abcdef1234567890abcdef1234")

HTML_BODY = (
    f"<html><head><title>pantoken</title></head>"
    f"<body><h1>pantoken {HTML_VERSION}</h1>"
    f"<p>build: {BUILD_SHA}</p></body></html>"
)

HEALTH_OK = '{"ok":true}'
HEALTH_FAIL = '{"ok":false}'


class FixtureHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/health":
            body = HEALTH_FAIL and HEALTH_FAIL or HEALTH_OK
            data = body.encode() if isinstance(body, str) else body
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        elif self.path == "/ws":
            self.send_response(101)
            self.send_header("Upgrade", "websocket")
            self.send_header("Connection", "upgrade")
            self.end_headers()
        elif self.path.startswith("/"):
            data = HTML_BODY.encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/html")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, format, *args):
        # Suppress default logging noise
        pass


if PORT == 0:
    # Find a free port
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("", 0))
        PORT = s.getsockname()[1]
    server = socketserver.TCPServer(("", PORT), FixtureHandler)
else:
    server = socketserver.TCPServer(("", PORT), FixtureHandler)

print(f"pantoken-fixture port={PORT} version={HTML_VERSION}", flush=True)
server.serve_forever()
