// PushSubscriptionStore is the file-backed subscription set extracted from PushService
// (which keeps the VAPID/crypto + web-push-lib shell). The store is the regression-prone
// state logic — add is idempotent by endpoint, remove/prune no-op when nothing matches,
// persist round-trips across instances. tmpdir-injectable via the ctor file param (same
// pattern as ArchiveStore / WorktreeStore), no VAPID key generation or global-lib
// mutation needed to construct it.

import { afterEach, beforeEach, describe, expect, test } from "bun:test";
import { mkdtempSync, readFileSync, rmSync, writeFileSync } from "node:fs";
import { tmpdir } from "node:os";
import { join } from "node:path";
import type { PushSubscription } from "web-push";
import { PushSubscriptionStore } from "./push.js";

const sub = (endpoint: string): PushSubscription =>
  ({
    endpoint,
    keys: { auth: `auth-${endpoint}`, p256dh: `p256-${endpoint}` },
  }) as PushSubscription;

describe("PushSubscriptionStore", () => {
  let dir: string;
  let file: string;
  beforeEach(() => {
    dir = mkdtempSync(join(tmpdir(), "pantoken-push-store-"));
    file = join(dir, "subs.json");
  });
  afterEach(() => rmSync(dir, { recursive: true, force: true }));

  test("empty store: count 0, values empty, no file yet", () => {
    const s = new PushSubscriptionStore(file);
    expect(s.count).toBe(0);
    expect(s.values()).toEqual([]);
  });

  test("add stores + counts + persists across instances", () => {
    const s1 = new PushSubscriptionStore(file);
    s1.add(sub("https://fcm/a"));
    s1.add(sub("https://fcm/b"));
    expect(s1.count).toBe(2);
    const s2 = new PushSubscriptionStore(file); // reload from disk
    expect(s2.count).toBe(2);
    expect(
      s2
        .values()
        .map((s) => s.endpoint)
        .sort(),
    ).toEqual(["https://fcm/a", "https://fcm/b"]);
  });

  test("add is idempotent by endpoint (re-subscribing a device is a no-op)", () => {
    // The whole point of keying by endpoint: a phone re-subscribing after a wake
    // doesn't create a duplicate (which would double-send). The latest sub object
    // wins (keys may have rotated).
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    s.add({
      ...sub("https://fcm/a"),
      keys: { auth: "rotated", p256dh: "rotated" },
    });
    expect(s.count).toBe(1);
    expect(s.values()[0]?.keys.auth).toBe("rotated");
  });

  test("remove drops a subscription and persists", () => {
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    s.add(sub("https://fcm/b"));
    s.remove("https://fcm/a");
    expect(s.count).toBe(1);
    expect(s.values()[0]?.endpoint).toBe("https://fcm/b");
    // persisted:
    expect(new PushSubscriptionStore(file).count).toBe(1);
  });

  test("remove is a no-op for an unknown endpoint (no persist, no error)", () => {
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    const before = readFileSync(file, "utf8");
    s.remove("https://fcm/never-added");
    expect(s.count).toBe(1);
    expect(readFileSync(file, "utf8")).toBe(before); // no rewrite
  });

  test("prune drops a batch of endpoints in one persist", () => {
    // The sendToAll sweep collects dead endpoints then prunes once (not one persist
    // per delete). Pins the batch path + single persist.
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    s.add(sub("https://fcm/b"));
    s.add(sub("https://fcm/c"));
    s.prune(["https://fcm/a", "https://fcm/c"]);
    expect(s.count).toBe(1);
    expect(s.values()[0]?.endpoint).toBe("https://fcm/b");
    expect(new PushSubscriptionStore(file).count).toBe(1);
  });

  test("prune with an empty list is a no-op (no persist)", () => {
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    const before = readFileSync(file, "utf8");
    s.prune([]);
    expect(s.count).toBe(1);
    expect(readFileSync(file, "utf8")).toBe(before);
  });

  test("prune tolerates endpoints that aren't present (mixed live + unknown)", () => {
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    s.add(sub("https://fcm/b"));
    s.prune(["https://fcm/a", "https://fcm/unknown"]);
    expect(s.count).toBe(1);
    expect(s.values()[0]?.endpoint).toBe("https://fcm/b");
  });

  test("a malformed subs file falls back to empty, never throws", () => {
    // House rule: surface + fall back, don't brick startup.
    const s = new PushSubscriptionStore(file);
    s.add(sub("https://fcm/a"));
    writeFileSync(file, "{ not valid json");
    const reloaded = new PushSubscriptionStore(file);
    expect(reloaded.count).toBe(0); // corrupt file → empty, not a throw
  });
});
