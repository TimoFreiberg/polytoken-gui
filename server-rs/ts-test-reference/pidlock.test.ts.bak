import { describe, expect, test } from "bun:test";
import { existsSync, mkdtempSync, readFileSync, rmSync } from "node:fs";
import { tmpdir } from "node:os";
import { join } from "node:path";
import {
  LockHeldError,
  acquirePidLock,
  isPidAlive,
  lockDecision,
  mintOrReadServerId,
  parseLock,
} from "./pidlock.js";

function freshDir(): string {
  return mkdtempSync(join(tmpdir(), "pantoken-pidlock-"));
}

// A pid that is essentially never live. 2^30 is far above any real pid on
// macOS/Linux, so process.kill(.., 0) reports ESRCH (dead).
const DEAD_PID = 1 << 30;

describe("parseLock", () => {
  test("parses a JSON object with pid + serverId", () => {
    expect(parseLock('{"pid":1234,"serverId":"abc"}')).toEqual({
      pid: 1234,
      serverId: "abc",
    });
  });

  test("parses a bare integer", () => {
    expect(parseLock("1234")).toEqual({ pid: 1234 });
  });

  test("tolerates trailing whitespace on a bare integer", () => {
    expect(parseLock("1234\n")).toEqual({ pid: 1234 });
  });

  test("returns null for empty / garbage / non-positive pids", () => {
    expect(parseLock("")).toBeNull();
    expect(parseLock("   ")).toBeNull();
    expect(parseLock("not-a-pid")).toBeNull();
    expect(parseLock('{"pid":0}')).toBeNull();
    expect(parseLock('{"pid":-5}')).toBeNull();
    expect(parseLock('{"serverId":"x"}')).toBeNull();
  });
});

describe("isPidAlive", () => {
  test("our own pid is alive", () => {
    expect(isPidAlive(process.pid)).toBe(true);
  });

  test("an absurdly high pid is not alive", () => {
    expect(isPidAlive(DEAD_PID)).toBe(false);
  });
});

describe("lockDecision", () => {
  test("no existing lock -> reclaim", () => {
    expect(lockDecision(null, process.pid)).toBe("reclaim");
  });

  test("lock owned by us -> reclaim (re-entrant)", () => {
    expect(lockDecision({ pid: process.pid }, process.pid)).toBe("reclaim");
  });

  test("a dead pid -> reclaim", () => {
    expect(lockDecision({ pid: DEAD_PID }, process.pid)).toBe("reclaim");
  });

  test("a live foreign pid -> live", () => {
    // process.pid is live; pretend a *different* selfPid so it's foreign.
    expect(lockDecision({ pid: process.pid }, process.pid + 1)).toBe("live");
  });
});

describe("acquirePidLock", () => {
  test("writes our pid + serverId and the file exists", () => {
    const dir = freshDir();
    try {
      const lock = acquirePidLock(dir, "server-abc", 4242);
      expect(existsSync(lock.path)).toBe(true);
      const parsed = parseLock(readFileSync(lock.path, "utf8"));
      expect(parsed).toEqual({ pid: 4242, serverId: "server-abc" });
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });

  test("reclaims a STALE lock (dead pid) and overwrites it", () => {
    const dir = freshDir();
    try {
      // Plant a stale lock from a dead pid.
      acquirePidLock(dir, "old-server", DEAD_PID);
      // A real server (our own live pid) reclaims it.
      const lock = acquirePidLock(dir, "new-server", process.pid);
      const parsed = parseLock(readFileSync(lock.path, "utf8"));
      expect(parsed).toEqual({ pid: process.pid, serverId: "new-server" });
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });

  test("a LIVE foreign lock makes acquire throw LockHeldError", () => {
    const dir = freshDir();
    try {
      // Plant a lock held by our own (live) pid...
      acquirePidLock(dir, "holder", process.pid);
      // ...then a *different* process tries to acquire -> blocked.
      expect(() => acquirePidLock(dir, "intruder", process.pid + 1)).toThrow(
        LockHeldError,
      );
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });

  test("release() removes our lock file", () => {
    const dir = freshDir();
    try {
      const lock = acquirePidLock(dir, "s", process.pid);
      expect(existsSync(lock.path)).toBe(true);
      lock.release();
      expect(existsSync(lock.path)).toBe(false);
      lock.release(); // idempotent
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });

  test("release() does not delete a lock another pid took over", () => {
    const dir = freshDir();
    try {
      const lock = acquirePidLock(dir, "s", 4242);
      // Simulate a takeover: another process reclaims the (stale) lock.
      acquirePidLock(dir, "other", process.pid);
      lock.release();
      // The takeover lock survives.
      expect(existsSync(lock.path)).toBe(true);
      const parsed = parseLock(readFileSync(lock.path, "utf8"));
      expect(parsed?.pid).toBe(process.pid);
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });
});

describe("mintOrReadServerId", () => {
  test("mints a hex id and is stable across reads", () => {
    const dir = freshDir();
    try {
      const a = mintOrReadServerId(dir);
      expect(a).toMatch(/^[0-9a-f]{32}$/);
      const b = mintOrReadServerId(dir);
      expect(b).toBe(a);
    } finally {
      rmSync(dir, { recursive: true, force: true });
    }
  });

  test("different data dirs get different ids", () => {
    const d1 = freshDir();
    const d2 = freshDir();
    try {
      expect(mintOrReadServerId(d1)).not.toBe(mintOrReadServerId(d2));
    } finally {
      rmSync(d1, { recursive: true, force: true });
      rmSync(d2, { recursive: true, force: true });
    }
  });
});
