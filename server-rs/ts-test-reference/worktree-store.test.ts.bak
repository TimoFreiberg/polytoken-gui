// WorktreeStore mirrors ArchiveStore (tmpdir-injectable via the ctor `file` param) but
// has richer state logic: REAPING IS A TOMBSTONE, not a delete. get() returns reaped
// entries (so grouping under the parent project survives a reaped dir), live() excludes
// them (the cleanup ownership gate), markReaped() keeps meta + flags it, and add() on a
// reaped path REVIVES it. That state machine is the valuable, regression-prone part —
// the archive-store tests don't cover it. These pin each transition + persistence.

import { afterEach, beforeEach, describe, expect, test } from "bun:test";
import { mkdtempSync, readFileSync, rmSync } from "node:fs";
import { tmpdir } from "node:os";
import { join } from "node:path";
import type { WorktreeMeta } from "./shared/worktree.js";
import { WorktreeStore } from "./worktree-store.js";

const meta = (path: string, base = "/repo"): WorktreeMeta => ({
  path,
  base,
  vcs: "jj",
  name: path.slice(1),
});

describe("WorktreeStore", () => {
  let dir: string;
  let file: string;
  beforeEach(() => {
    dir = mkdtempSync(join(tmpdir(), "pantoken-worktree-"));
    file = join(dir, "worktrees.json");
  });
  afterEach(() => rmSync(dir, { recursive: true, force: true }));

  test("get() is undefined for an unknown path", () => {
    expect(new WorktreeStore(file).get("/wt-a")).toBeUndefined();
  });

  test("add() stores + persists the meta across instances", () => {
    const s1 = new WorktreeStore(file);
    s1.add(meta("/wt-a"));
    s1.add(meta("/wt-b", "/other"));
    const s2 = new WorktreeStore(file);
    expect(s2.get("/wt-a")).toEqual(meta("/wt-a"));
    expect(s2.get("/wt-b")).toEqual(meta("/wt-b", "/other"));
    expect(s2.get("/wt-c")).toBeUndefined();
  });

  test("live() returns the worktree when not reaped", () => {
    const s = new WorktreeStore(file);
    s.add(meta("/wt-a"));
    expect(s.live("/wt-a")).toEqual(meta("/wt-a"));
  });

  test("markReaped tombstones: get() still returns meta, live() excludes it", () => {
    // The core invariant: reaping keeps the meta (for sidebar grouping under the parent
    // project's `base`) but drops it from the live ownership gate (so cleanup won't try
    // to reap an already-gone dir twice).
    const s = new WorktreeStore(file);
    s.add(meta("/wt-a"));
    s.markReaped("/wt-a");
    expect(s.get("/wt-a")).toEqual(meta("/wt-a")); // survives for grouping
    expect(s.isReaped("/wt-a")).toBe(true);
    expect(s.live("/wt-a")).toBeUndefined(); // excluded from the live gate
  });

  test("markReaped is a no-op for an unknown path (no phantom tombstone)", () => {
    const s = new WorktreeStore(file);
    s.markReaped("/never-added");
    expect(s.isReaped("/never-added")).toBe(false);
    expect(s.get("/never-added")).toBeUndefined();
  });

  test("markReaped is idempotent (re-marking a reaped path doesn't double-write)", () => {
    const s = new WorktreeStore(file);
    s.add(meta("/wt-a"));
    s.markReaped("/wt-a");
    const before = readFileSync(file, "utf8");
    s.markReaped("/wt-a"); // already reaped — no change, no persist
    expect(readFileSync(file, "utf8")).toBe(before);
  });

  test("add() on a reaped path revives it (reaped flag cleared)", () => {
    // A path reused after a prior reap starts live again — defensive against a worktree
    // dir getting recreated at the same location.
    const s = new WorktreeStore(file);
    s.add(meta("/wt-a"));
    s.markReaped("/wt-a");
    expect(s.isReaped("/wt-a")).toBe(true);
    s.add(meta("/wt-a")); // revive
    expect(s.isReaped("/wt-a")).toBe(false);
    expect(s.live("/wt-a")).toEqual(meta("/wt-a"));
  });

  test("tombstone + reaped flag persist across instances", () => {
    const s1 = new WorktreeStore(file);
    s1.add(meta("/wt-a"));
    s1.add(meta("/wt-b"));
    s1.markReaped("/wt-a");
    const s2 = new WorktreeStore(file);
    expect(s2.get("/wt-a")).toEqual(meta("/wt-a")); // meta survived
    expect(s2.isReaped("/wt-a")).toBe(true); // tombstone survived
    expect(s2.live("/wt-a")).toBeUndefined();
    expect(s2.live("/wt-b")).toEqual(meta("/wt-b")); // wt-b still live
  });

  test("persisted shape stamps reaped entries with a reaped:true flag", () => {
    // The on-disk format: a reaped entry carries { ...meta, reaped: true }; a live one
    // carries just the meta. Pins the load() round-trip that reconstructs the tombstone.
    const s = new WorktreeStore(file);
    s.add(meta("/live"));
    s.add(meta("/dead"));
    s.markReaped("/dead");
    const onDisk = JSON.parse(readFileSync(file, "utf8"));
    const live = onDisk.find((e: { path: string }) => e.path === "/live");
    const dead = onDisk.find((e: { path: string }) => e.path === "/dead");
    expect(live.reaped).toBeUndefined();
    expect(dead.reaped).toBe(true);
  });

  test("a missing index file loads as empty, not an error", () => {
    expect(
      new WorktreeStore(join(dir, "nope.json")).get("/wt-a"),
    ).toBeUndefined();
  });
});
