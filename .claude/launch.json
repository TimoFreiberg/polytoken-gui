{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "pantoken",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "PANTOKEN_DRIVER=mock bun run scripts/dev.ts"
      ],
      "autoPort": true
    },
    {
      "name": "pantoken-real",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "pantoken-parity",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "parity/launch.ts"],
      "autoPort": true
    }
  ]
}
