{
  "name": "pilot",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "workspaces": ["protocol", "server", "client"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --cwd server dev",
    "dev:client": "bun run --cwd client dev",
    "build": "bun run --cwd client build",
    "start": "bun run --cwd server start",
    "test": "bun test protocol server client/src scripts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "check": "tsc -p protocol/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p tsconfig.extensions.json --noEmit && bun run --cwd client check",
    "deploy:now": "bash scripts/deploy-now.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "patchedDependencies": {
    "@earendil-works/pi-ai@0.80.2": "patches/@earendil-works%2Fpi-ai@0.80.2.patch"
  }
}
